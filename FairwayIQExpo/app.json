{
  "expo": {
    "name": "Fairway IQ",
    "slug": "fairwaysiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Fairway IQ uses your location to calculate yardage and recommend a club for the current shot."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "cc75f53a-cb1e-42b8-bfad-61e9bd6c6fb8"
      }
    },
    "owner": "brichstayfrostyapps"
  }
}
